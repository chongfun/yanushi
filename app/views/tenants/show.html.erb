
<div class="max-w-4xl mx-auto py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold">Tenant Profile</h1>
      <p class="text-base-content/60">System ID: <%= dom_id(@tenant) %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Back to List", tenants_path, class: "btn btn-ghost" %>
      <%= link_to "Edit Profile", edit_tenant_path(@tenant), class: "btn btn-outline" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Contact Info Card -->
    <div class="card bg-base-100 shadow-xl border border-base-200">
      <div class="card-body items-center text-center">
        <div class="avatar placeholder mb-4">
          <div class="bg-neutral text-neutral-content w-24 rounded-full">
            <span class="text-3xl"><%= @tenant.name.split.map(&:first).join.upcase %></span>
          </div>
        </div>
        <h2 class="card-title text-2xl font-bold"><%= @tenant.name %></h2>
        
        <div class="divider w-full"></div>
        
        <div class="w-full space-y-4">
          <% if @tenant.email_address.present? %>
            <div class="text-left">
              <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1">Email</div>
              <%= mail_to @tenant.email_address, class: "flex items-center gap-2 text-primary hover:underline" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="font-medium"><%= @tenant.email_address %></span>
              <% end %>
            </div>
          <% end %>

          <% if @tenant.phone_number.present? %>
            <div class="text-left">
              <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1">Phone</div>
              <a href="tel:<%= @tenant.phone_number %>" class="flex items-center gap-2 text-primary hover:underline">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span class="font-medium"><%= @tenant.phone_number %></span>
              </a>
            </div>
          <% end %>

          <div class="text-left">
            <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-1">Mailing Address</div>
            <div class="text-sm leading-relaxed text-base-content/80">
              <%= @tenant.mailing_address.presence || "No address on file" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lease History / Details -->
    <div class="lg:col-span-2 space-y-6">
      <div class="card bg-base-100 shadow-xl border border-base-200">
        <div class="card-body">
          <h3 class="card-title text-xl mb-4">Active Lease Agreements</h3>
          
          <% if @tenant.leases.any? %>
            <div class="space-y-4">
              <% @tenant.leases.each do |lease| %>
                <div class="bg-base-200 p-4 rounded-xl border border-base-300 flex justify-between items-center">
                  <div>
                    <div class="font-bold text-lg"><%= lease.rental_property.address %></div>
                    <div class="text-sm text-base-content/60">
                      <%= lease.commencement_date.strftime("%b %Y") %> - <%= lease.termination_date&.strftime("%b %Y") || "Ongoing" %>
                    </div>
                  </div>
                  <%= link_to "View Lease", lease, class: "btn btn-sm btn-ghost" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="alert bg-base-200 border-base-300">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span>This tenant currently has no active lease agreements.</span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card bg-base-100 shadow-xl border border-base-200 overflow-hidden">
        <div class="card-body p-0">
          <div class="bg-error/10 p-6 flex justify-between items-center">
            <div>
              <h4 class="font-bold text-error">Danger Zone</h4>
              <p class="text-xs text-error/80">Deleting a tenant record cannot be undone.</p>
            </div>
            <%= button_to "Delete Tenant", @tenant, method: :delete, 
                class: "btn btn-error btn-sm", 
                form: { data: { turbo_confirm: "Are you sure you want to delete this tenant? This action is irreversible." } } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

