<% content_for :title, "Notifications" %>

<% content_for :breadcrumbs do %>
  <li>Notifications</li>
<% end %>

<div class="flex justify-between items-center mb-8">
  <div>
    <h1 class="text-3xl font-extrabold tracking-tight">Notifications</h1>
    <p class="text-base-content/70 mt-1">Stay updated on parsed payment sync status and alerts.</p>
  </div>
  <% if @notifications.unread.any? %>
    <%= button_to mark_all_read_notifications_path, method: :post, class: "btn btn-outline btn-neutral btn-sm" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
      Mark all as read
    <% end %>
  <% end %>
</div>

<% if @notifications.any? %>
  <div class="flex flex-col gap-4">
    <% @notifications.each do |notification| %>
      <div class="card bg-base-100 border <%= notification.read? ? 'border-base-200 opacity-75' : 'border-primary/30 shadow-md bg-gradient-to-r from-base-100 to-primary/5' %> transition-all rounded-lg overflow-hidden">
        <div class="card-body p-6 flex flex-row items-start justify-between gap-4">
          <div class="flex items-start gap-4">
            <!-- Icon based on read status / type -->
            <div class="p-3 rounded-lg <%= notification.read? ? 'bg-base-200 text-base-content/60' : 'bg-primary/10 text-primary' %> mt-1 shrink-0">
              <% if notification.payment_unmatched? %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" /></svg>
              <% else %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" /></svg>
              <% end %>
            </div>

            <div>
              <h3 class="font-bold text-lg flex items-center gap-2">
                <%= notification.title %>
                <% unless notification.read? %>
                  <span class="badge badge-primary badge-sm">New</span>
                <% end %>
              </h3>
              <p class="text-base-content/80 mt-1 text-sm"><%= notification.message %></p>
              
              <div class="flex items-center gap-4 mt-3 text-xs text-base-content/50">
                <span><%= time_ago_in_words(notification.created_at) %> ago</span>
                <% if notification.payment_email %>
                  <span>•</span>
                  <%= link_to "View email source", payment_email_path(notification.payment_email), class: "link link-primary font-medium" %>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <% unless notification.read? %>
            <%= button_to mark_read_notification_path(notification), method: :post, class: "btn btn-ghost btn-sm text-primary", title: "Mark as read" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 bg-base-100 rounded-lg shadow-sm border border-base-200">
    <div class="inline-flex p-4 bg-base-200 rounded-full text-base-content/40 mb-4 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" /></svg>
    </div>
    <h3 class="font-extrabold text-xl">All caught up!</h3>
    <p class="text-base-content/60 mt-1 max-w-md mx-auto text-sm">You don't have any notifications right now. We'll alert you here if any payment emails fail to match your tenants.</p>
  </div>
<% end %>
