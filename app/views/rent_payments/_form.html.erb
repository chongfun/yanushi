<%= form_with(model: rent_payment) do |form| %>
  <% if rent_payment.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(rent_payment.errors.count, "error") %> prohibited this rent_payment from being saved:</h2>

      <ul>
        <% rent_payment.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :scheduled_rent_id, style: "display: block" %>
    <%= form.collection_select :scheduled_rent_id, ScheduledRent.all, :id, :display_name %>
  </div>

  <div>
    <%= form.label :payment_date, style: "display: block" %>
    <%= form.date_field :payment_date %>
  </div>

  <div>
    <%= form.label :amount, style: "display: block" %>
    <%= form.text_field :amount %>
  </div>

  <div>
    <%= form.label :payment_method, style: "display: block" %>
    <%= form.text_field :payment_method %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
