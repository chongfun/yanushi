
<% content_for :title, "Rent payments" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold">Rent payments</h1>
  <%= link_to "New rent payment", new_rent_payment_path, class: "btn btn-primary" %>
</div>


<div class="overflow-x-auto bg-base-100 rounded-lg shadow border border-base-200">
  <table class="table table-zebra w-full">
    <thead>
      <tr>
        <th>Scheduled Rent</th>
        <th>Payment Date</th>
        <th>Amount</th>
        <th>Method</th>
        <th>Transaction #</th>
        <th class="text-right">Actions</th>
      </tr>
    </thead>
    <tbody id="rent_payments">
      <% @rent_payments.each do |rent_payment| %>
        <%= render rent_payment %>
      <% end %>
    </tbody>
  </table>
</div>


