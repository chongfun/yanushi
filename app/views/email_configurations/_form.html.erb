<%= form_with(model: @email_configuration, url: email_configuration_path, method: :patch, class: "space-y-6") do |f| %>
  <% if @email_configuration.errors.any? %>
    <div class="alert alert-error shadow-sm rounded-lg flex items-start gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <div>
        <h3 class="font-bold"><%= pluralize(@email_configuration.errors.count, "error") %> prohibited this configuration from being saved:</h3>
        <ul class="list-disc pl-5 mt-1 text-sm">
          <% @email_configuration.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="card bg-base-100 border border-base-200 shadow-sm">
    <div class="card-body gap-4">
      <h3 class="font-bold text-lg border-b border-base-200 pb-3 mb-2 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 text-primary"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205 3 1m1.5-1.5-3-1m-3.102-1.248L16.5 3.545M15 3h1.5m-3 9h.008v.008H13.5V12Zm0 2.25h.008v.008H13.5v-.008Zm0 2.25h.008v.008H13.5V16.5Zm-3-2.25h.008v.008H10.5v-.008Zm0 2.25h.008v.008H10.5V16.5Z" /></svg>
        IMAP Mailbox Connection
      </h3>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="form-control md:col-span-2">
          <%= f.label :imap_server, "IMAP Server Address", class: "label label-text font-semibold" %>
          <%= f.text_field :imap_server, placeholder: "e.g. imap.gmail.com or imap.mail.chase.com", class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :imap_port, "Connection Port", class: "label label-text font-semibold" %>
          <%= f.number_field :imap_port, class: "input input-bordered w-full" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
        <div class="form-control">
          <%= f.label :username, "Username / Email address", class: "label label-text font-semibold" %>
          <%= f.text_field :username, placeholder: "your-inbox@example.com", class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :password, "App-Specific Password", class: "label label-text font-semibold" %>
          <%= f.password_field :password, value: @email_configuration.password, placeholder: "🔐 App password (encrypted at rest)", class: "input input-bordered w-full" %>
          <label class="label">
            <span class="label-text-alt text-base-content/50">Never use your main password. Generate a secure "App Password" in your email provider settings.</span>
          </label>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
        <div class="form-control">
          <%= f.label :mailbox, "Target Mailbox Folder", class: "label label-text font-semibold" %>
          <%= f.text_field :mailbox, class: "input input-bordered w-full" %>
        </div>

        <div class="form-control flex flex-row items-center gap-6 mt-8 pl-2">
          <div class="flex items-center gap-2">
            <%= f.check_box :ssl, class: "checkbox checkbox-primary checkbox-sm" %>
            <%= f.label :ssl, "Use SSL/TLS Connection", class: "label-text font-medium cursor-pointer" %>
          </div>

          <div class="flex items-center gap-2">
            <%= f.check_box :enabled, class: "checkbox checkbox-primary checkbox-sm" %>
            <%= f.label :enabled, "Enable Ingestion Job", class: "label-text font-medium cursor-pointer" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3 border-t border-base-200 pt-6">
    <%= link_to "Cancel", email_configuration_path, class: "btn btn-ghost" %>
    <%= f.submit "Save Connection", class: "btn btn-primary px-8" %>
  </div>
<% end %>
