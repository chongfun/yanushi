<%= form_with(model: lease) do |form| %>
  <% if lease.errors.any? %>
    <div class="alert alert-error shadow-lg mb-6 text-error-content"><div>
      <h3 class="font-bold"><%= pluralize(lease.errors.count, "error") %> prohibited this lease from being saved:</h3>

      <ul>
        <% lease.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control w-full mb-4">
    <%= form.label :rental_property_id, class: "label font-semibold" %>
    <%= form.collection_select :rental_property_id, @rental_properties, :id, :address, {}, { class: "select select-bordered w-full" } %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :tenant_ids, "Tenants", class: "label font-semibold" %>
    <%= form.collection_select :tenant_ids, @tenants, :id, :name, {}, { multiple: true, class: "select select-bordered w-full h-32" } %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :lease_type, class: "label font-semibold" %>
    <%= form.select :lease_type, Lease.lease_types.keys.map { |k| [k.humanize, k] }, {}, { class: "select select-bordered w-full" } %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :commencement_date, class: "label font-semibold" %>
    <%= form.date_field :commencement_date, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :termination_date, class: "label font-semibold" %>
    <%= form.date_field :termination_date, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :annual_rental_amount, class: "label font-semibold" %>
    <%= form.text_field :annual_rental_amount, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :late_period_days, class: "label font-semibold" %>
    <%= form.number_field :late_period_days, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :security_deposit, class: "label font-semibold" %>
    <%= form.text_field :security_deposit, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary w-full mt-4" %>
  </div>
<% end %>
