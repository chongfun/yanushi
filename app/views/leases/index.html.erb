
<% content_for :title, "Leases" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold">Leases</h1>
  <%= link_to "New lease", new_lease_path, class: "btn btn-primary" %>
</div>

<div class="overflow-x-auto bg-base-100 rounded-lg shadow border border-base-200">
  <table class="table table-zebra w-full">
    <thead>
      <tr>
        <th>Property / Tenants</th>
        <th>Type</th>
        <th>Start Date</th>
        <th>End Date</th>
        <th>Annual Rent</th>
        <th class="text-right">Actions</th>
      </tr>
    </thead>
    <tbody id="leases">
      <% @leases.each do |lease| %>
        <%= render lease %>
      <% end %>
    </tbody>
  </table>
</div>


