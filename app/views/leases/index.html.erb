
<% content_for :title, "Leases" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold">Leases</h1>
  <%= link_to "New lease", new_lease_path, class: "btn btn-primary" %>
</div>


<div id="leases" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% @leases.each do |lease| %>
    <%= render lease %>
    
  <% end %>
</div>


