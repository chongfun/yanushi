<div id="<%= dom_id utility_payment %>" class="card bg-base-100 shadow-xl">
  <div class="card-body">
  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Tenant</span>
      <span class="font-medium"><%= utility_payment.tenant_id %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Rental property</span>
      <span class="font-medium"><%= utility_payment.rental_property_id %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Amount</span>
      <span class="font-medium"><%= utility_payment.amount %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Payment date</span>
      <span class="font-medium"><%= utility_payment.payment_date %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Payment method</span>
      <span class="font-medium"><%= utility_payment.payment_method %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Transaction number</span>
      <span class="font-medium"><%= utility_payment.transaction_number %></span>
    </div>

    <div class="card-actions justify-end mt-4">
      <%= link_to "View", utility_payment, class: "btn btn-sm btn-outline" %>
    </div>
  </div>
</div>
