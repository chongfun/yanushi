<%= form_with(model: utility_payment) do |form| %>
  <% if utility_payment.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(utility_payment.errors.count, "error") %> prohibited this utility_payment from being saved:</h2>

      <ul>
        <% utility_payment.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :tenant_id, style: "display: block" %>
    <%= form.collection_select :tenant_id, Tenant.all, :id, :name %>
  </div>

