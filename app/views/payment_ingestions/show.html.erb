<% content_for :title, "Review Payment Ingestion - Yanushi" %>

<% content_for :breadcrumbs do %>
  <li><%= link_to "Payment Ingestions", payment_ingestions_path %></li>
  <li>Review Ingestion #<%= @ingestion.id %></li>
<% end %>

<!-- Status Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6 pb-6 border-b border-base-200">
  <div>
    <h1 class="text-3xl font-extrabold text-base-content flex items-center gap-3">
      <span>Review Payment Ingestion</span>
      <% case @ingestion.status %>
      <% when "confirmed" %>
        <span class="badge badge-success gap-1 py-3 px-4 font-bold text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
          Confirmed
        </span>
      <% when "matched" %>
        <span class="badge badge-success font-semibold py-3 px-3">Matched</span>
      <% when "ambiguous" %>
        <span class="badge badge-warning font-semibold py-3 px-3">Ambiguous Match</span>
      <% when "unmatched" %>
        <span class="badge badge-neutral font-semibold py-3 px-3">Unmatched</span>
      <% when "failed" %>
        <span class="badge badge-error font-semibold py-3 px-3">Failed Parse</span>
      <% end %>
    </h1>
    <p class="text-sm text-base-content/70 mt-1">Uploaded on <%= @ingestion.created_at.in_time_zone(Current.session.user.timezone).strftime("%B %d, %Y at %I:%M %p") %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Back to Queue", payment_ingestions_path, class: "btn btn-outline btn-sm" %>
    <%= link_to "Delete Ingestion", payment_ingestion_path(@ingestion), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this ingestion record?" }, class: "btn btn-error btn-outline btn-sm" %>
  </div>
</div>

<% if @ingestion.confirmed? %>
  <!-- Success Confirmation Banner -->
  <div class="alert alert-success shadow-lg mb-8">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
    <div>
      <h3 class="font-bold text-lg">Transaction Confirmed!</h3>
      <p class="text-sm">This receipt was matched and verified. A tenant payment of <%= number_to_currency(@ingestion.amount) %> was created on <%= @ingestion.payment_date.strftime("%b %d, %Y") %>.</p>
    </div>
    <div class="flex-none">
      <%= link_to "View Tenant Payment", tenant_payment_path(@ingestion.tenant_payment), class: "btn btn-sm btn-outline text-success-content border-success-content/30 hover:bg-success-content/10" if @ingestion.tenant_payment %>
    </div>
  </div>
<% elsif @ingestion.failed? && @ingestion.error_message.present? %>
  <!-- Failed Parse Alert -->
  <div class="alert alert-error shadow-sm mb-8 text-sm">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
    <div>
      <h3 class="font-bold">PDF Parsing Failed</h3>
      <p><%= @ingestion.error_message %>. Please review the document on the left and enter all required details manually below.</p>
    </div>
  </div>
<% end %>

<% if @ingestion.duplicate_exists? %>
  <!-- Duplicate Alert -->
  <div class="alert alert-warning shadow-sm mb-8 text-sm">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
    <div>
      <h3 class="font-bold">Duplicate Payment Detected</h3>
      <p>A tenant payment with payment method "<%= @ingestion.payment_method %>" and transaction number "<%= @ingestion.transaction_number %>" already exists in the system. Confirmation is locked to prevent double entry.</p>
    </div>
  </div>
<% end %>

<!-- Main Side-by-Side Review Section -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
  <!-- Left Side: Dynamic Receipt Preview -->
  <div class="lg:col-span-6 flex flex-col space-y-2">
    <div class="flex items-center justify-between">
      <h3 class="font-bold text-lg text-base-content">Receipt Preview</h3>
      <% if @ingestion.attachment_attached? %>
        <%= link_to "Open Document in New Tab", download_payment_ingestion_path(@ingestion), target: "_blank", class: "link link-primary text-xs" %>
      <% end %>
    </div>
    <div class="border border-base-300 rounded-lg overflow-hidden shadow-inner bg-base-300 flex-grow" style="height: 600px;">
      <% if @ingestion.receipt_type == "chase_statement" && @ingestion.raw_text.present? %>
        <div class="p-6 h-full overflow-auto font-mono text-sm whitespace-pre-wrap bg-base-200 text-base-content shadow-inner leading-relaxed flex flex-col justify-center items-center text-center">
          <div class="text-xs uppercase tracking-wider text-base-content/40 font-bold mb-4">Extracted Statement Line Item</div>
          <div class="bg-base-100 p-4 rounded-lg border border-base-300 shadow-sm font-bold font-mono text-base text-base-content whitespace-pre-wrap break-all text-left w-full max-w-lg">
            <%= @ingestion.raw_text %>
          </div>
          <p class="text-xs text-base-content/50 mt-6">
            This transaction was extracted from a multi-page Chase statement.
            <br>
            Use the link above to view or download the full document.
          </p>
        </div>
      <% elsif @ingestion.attachment_attached? %>
        <% if @ingestion.attachment_image? %>
          <div class="flex items-center justify-center h-full bg-base-200 p-4">
            <%= image_tag download_payment_ingestion_path(@ingestion), class: "max-h-full max-w-full object-contain rounded shadow" %>
          </div>
        <% else %>
          <iframe src="<%= download_payment_ingestion_path(@ingestion, anchor: 'navpanes=0&pagemode=none') %>" class="w-full h-full border-0" title="Receipt Preview"></iframe>
        <% end %>
      <% elsif @ingestion.raw_text.present? %>
        <div class="p-6 h-full overflow-auto font-mono text-sm whitespace-pre-wrap bg-base-200 text-base-content shadow-inner leading-relaxed">
          <%= @ingestion.raw_text %>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center h-full text-base-content/50 space-y-2 p-6 bg-base-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="text-sm font-medium">No preview available</span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Right Side: Edit Form and Confirmation -->
  <div class="lg:col-span-6 space-y-6">
    <div class="card bg-base-100 border border-base-200 shadow-lg">
      <div class="card-body space-y-6">
        <h3 class="card-title text-xl font-bold text-base-content">Extracted & Match Details</h3>

        <% unless @ingestion.confirmed? %>
          <%= form_with(model: @ingestion, local: true, class: "space-y-4", data: { controller: "payment-ingestion-form", payment_ingestion_form_tenant_leases_value: @tenant_leases_map.to_json, payment_ingestion_form_lease_tenants_value: @lease_tenants_map.to_json }) do |f| %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Tenant</span></label>
                <%= f.select :tenant_id, @tenants.map { |t| [t.name, t.id] }, { include_blank: "Select Tenant" }, class: "select select-bordered w-full", data: { payment_ingestion_form_target: "tenantSelect", action: "change->payment-ingestion-form#tenantChanged" } %>
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Lease</span></label>
                <%= f.select :lease_id, @leases.map { |l| [ "#{l.rental_property.address} - #{l.lease_type.titleize} (Commenced #{l.commencement_date.strftime('%b %Y')})", l.id ] }, { include_blank: "Select Lease" }, class: "select select-bordered w-full", data: { payment_ingestion_form_target: "leaseSelect", action: "change->payment-ingestion-form#leaseChanged" } %>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Payment Date</span></label>
                <%= f.date_field :payment_date, class: "input input-bordered w-full" %>
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Amount</span></label>
                <div class="join w-full">
                  <span class="btn join-item pointer-events-none">$</span>
                  <%= f.number_field :amount, step: "0.01", class: "input input-bordered join-item w-full" %>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Payment Method</span></label>
                <%= f.select :payment_method, PaymentIngestion::PAYMENT_METHODS, { include_blank: "Select Method" }, class: "select select-bordered w-full" %>
              </div>

              <div class="form-control">
                <label class="label"><span class="label-text font-semibold">Transaction Number</span></label>
                <%= f.text_field :transaction_number, class: "input input-bordered w-full font-mono text-sm" %>
              </div>
            </div>

            <!-- Extra Extracted Payer Info (Read Only or Informational) -->
            <div class="bg-base-200/50 p-3 rounded-lg text-xs space-y-1 mt-2">
              <div class="font-bold text-base-content/85">Original PDF Metadata:</div>
              <div>Payer Name: <span class="font-semibold"><%= @ingestion.payer_name.presence || "—" %></span></div>
              <% if @ingestion.payer_username.present? %>
                <div>Payer Handle: <span class="font-semibold font-mono"><%= @ingestion.payer_username %></span></div>
              <% end %>
            </div>

            <div class="flex justify-end pt-2">
              <%= f.submit "Save Corrections", class: "btn btn-outline btn-primary btn-sm" %>
            </div>
          <% end %>

          <div class="divider"></div>

          <!-- Step B: Final Confirmation Form -->
          <div class="space-y-4">
            <h4 class="font-bold text-md text-base-content">Record to Ledger</h4>
            
            <% if @ingestion.confirmable? %>
              <%= form_with(url: confirm_payment_ingestion_path(@ingestion), method: :post, local: true, class: "space-y-4") do %>
                <!-- Checkbox to auto-add aliases -->
                <% alias_name_proposal = payment_ingestion_alias_proposal(@ingestion) %>

                <% if alias_name_proposal %>
                  <div class="form-control bg-primary/5 border border-primary/20 rounded-lg p-3">
                    <label class="flex items-start gap-3 cursor-pointer select-none">
                      <%= check_box_tag :create_alias, "1", true, class: "checkbox checkbox-primary checkbox-sm mt-0.5" %>
                      <div class="flex-1 min-w-0">
                        <span class="label-text font-bold text-primary block mb-0.5">Add tenant alias</span>
                        <p class="text-xs text-base-content/60 leading-normal break-words">Automatically associate payer identifier "<%= alias_name_proposal %>" with this tenant for future uploads.</p>
                      </div>
                    </label>
                  </div>
                <% end %>

                <button type="submit" class="btn btn-success btn-block gap-2 shadow-md">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                  Confirm & Record Tenant Payment
                </button>
              <% end %>
            <% else %>
              <div class="bg-base-200 border border-base-300 rounded-lg p-4 text-center">
                <p class="text-sm text-base-content/60 mb-2">To confirm this payment, please correct the form above to ensure all fields are complete.</p>
                <div class="flex flex-wrap justify-center gap-2 text-xs">
                  <span class="badge <%= @ingestion.tenant_id ? 'badge-success' : 'badge-neutral/30' %>">Tenant</span>
                  <span class="badge <%= @ingestion.lease_id ? 'badge-success' : 'badge-neutral/30' %>">Lease</span>
                  <span class="badge <%= @ingestion.amount ? 'badge-success' : 'badge-neutral/30' %>">Amount</span>
                  <span class="badge <%= @ingestion.payment_date ? 'badge-success' : 'badge-neutral/30' %>">Date</span>
                  <span class="badge <%= !@ingestion.duplicate_exists? ? 'badge-success' : 'badge-error' %>">Not Duplicate</span>
                </div>
                <button class="btn btn-block btn-disabled mt-4">Confirm & Record Tenant Payment</button>
              </div>
            <% end %>
          </div>

        <% else %>
          <!-- Show Read-Only Details for Confirmed Ingestions -->
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-4 text-sm border-t border-base-200 pt-4">
              <div>
                <span class="text-base-content/50 block">Tenant</span>
                <span class="font-bold text-base-content"><%= @ingestion.tenant&.name %></span>
              </div>
              <div>
                <span class="text-base-content/50 block">Property / Lease</span>
                <span class="font-bold text-base-content"><%= @ingestion.lease&.rental_property&.address %></span>
              </div>
              <div>
                <span class="text-base-content/50 block">Payment Date</span>
                <span class="font-bold text-base-content"><%= @ingestion.payment_date&.strftime("%b %d, %Y") %></span>
              </div>
              <div>
                <span class="text-base-content/50 block">Confirmed Amount</span>
                <span class="font-bold text-success"><%= number_to_currency(@ingestion.amount) %></span>
              </div>
              <div>
                <span class="text-base-content/50 block">Payment Method</span>
                <span class="font-bold text-base-content capitalize"><%= @ingestion.payment_method %></span>
              </div>
              <div>
                <span class="text-base-content/50 block">Transaction Number</span>
                <span class="font-mono font-bold text-base-content"><%= @ingestion.transaction_number.presence || "—" %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
