<% content_for :title, "Payment Ingestions - Yanushi" %>

<% content_for :breadcrumbs do %>
  <li>Payment Ingestions</li>
<% end %>

<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
  <div>
    <h1 class="text-3xl font-extrabold tracking-tight text-base-content">Payment Ingestion</h1>
    <p class="text-base-content/70 mt-1">Upload and review payments to automate tenant payment entry.</p>
  </div>
  <div>
    <%= link_to new_payment_ingestion_path, class: "btn btn-primary gap-2" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
      Upload Document
    <% end %>
  </div>
</div>

<div class="space-y-12">
  <% if @processing_documents.any? || @failed_documents.any? %>
    <!-- Section: Recent Uploads -->
    <div>
      <h2 class="text-xl font-bold text-base-content mb-4 flex items-center gap-2">
        <span>Recent Uploads</span>
        <span class="badge badge-primary font-semibold"><%= @processing_documents.size + @failed_documents.size %></span>
      </h2>

      <div class="overflow-x-auto card bg-base-100 border border-base-200 shadow-md">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>File Name</th>
              <th>Status</th>
              <th>Uploaded At</th>
              <th>Details / Error Message</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @processing_documents.each do |doc| %>
              <tr class="animate-pulse">
                <td class="whitespace-nowrap font-medium text-sm">
                  <%= doc.attachment_filename %>
                </td>
                <td>
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-primary">
                    <span class="h-2 w-2 rounded-full bg-primary animate-ping"></span>
                    Processing...
                  </span>
                </td>
                <td class="text-xs text-base-content/60">
                  <%= doc.created_at.in_time_zone(Current.session.user.timezone).strftime("%b %d, %Y %I:%M %p") %>
                </td>
                <td class="text-sm text-base-content/50 italic">
                  Parsing and extracting document details...
                </td>
                <td class="text-right">
                  <%= link_to "Cancel", payment_document_path(doc), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to cancel processing this document?" }, class: "btn btn-sm btn-ghost text-error" %>
                </td>
              </tr>
            <% end %>

            <% @failed_documents.each do |doc| %>
              <tr>
                <td class="whitespace-nowrap font-medium text-sm">
                  <%= doc.attachment_filename %>
                </td>
                <td>
                  <span class="badge badge-error text-xs font-semibold">Failed</span>
                </td>
                <td class="text-xs text-base-content/60">
                  <%= doc.created_at.in_time_zone(Current.session.user.timezone).strftime("%b %d, %Y %I:%M %p") %>
                </td>
                <td class="text-sm text-error font-medium">
                  <%= doc.error_message.presence || "Unknown parsing error" %>
                </td>
                <td class="text-right">
                  <%= link_to "Dismiss", payment_document_path(doc), data: { turbo_method: :delete }, class: "btn btn-sm btn-ghost" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <!-- Section: Review Queue -->
  <div>
    <h2 class="text-xl font-bold text-base-content mb-4 flex items-center gap-2">
      <span>Review Queue</span>
      <% if @reviewable_ingestions.any? %>
        <span class="badge badge-secondary font-semibold"><%= @reviewable_ingestions.size %></span>
      <% end %>
    </h2>

    <% if @reviewable_ingestions.empty? %>
      <div class="card bg-base-100 border border-base-200 shadow-sm py-12">
        <div class="text-center max-w-md mx-auto space-y-4">
          <div class="inline-flex p-4 rounded-full bg-success/10 text-success">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold">All caught up!</h3>
          <p class="text-sm text-base-content/60">No payment receipts require review. Upload a new PDF receipt to get started.</p>
        </div>
      </div>
    <% else %>
      <div class="overflow-x-auto card bg-base-100 border border-base-200 shadow-md">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Uploaded At</th>
              <th>Receipt Type</th>
              <th>Parsed Payer</th>
              <th>Parsed Amount</th>
              <th>Parsed Date</th>
              <th>Resolved Tenant</th>
              <th>Status</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @reviewable_ingestions.each do |ingestion| %>
              <tr>
                <td class="whitespace-nowrap font-medium text-xs text-base-content/70">
                  <%= ingestion.created_at.in_time_zone(Current.session.user.timezone).strftime("%b %d, %Y %I:%M %p") %>
                </td>
                <td>
                  <span class="badge badge-outline text-xs"><%= ingestion.receipt_type.present? ? ingestion.receipt_type.titleize : "Unknown" %></span>
                </td>
                <td>
                  <div class="font-semibold text-sm">
                    <%= ingestion.payer_name.presence || "—" %>
                  </div>
                  <% if ingestion.payer_username.present? %>
                    <div class="text-xs text-base-content/50"><%= ingestion.payer_username %></div>
                  <% end %>
                </td>
                <td class="font-bold text-sm">
                  <%= ingestion.amount.present? ? number_to_currency(ingestion.amount) : "—" %>
                </td>
                <td class="text-xs">
                  <%= ingestion.payment_date.present? ? ingestion.payment_date.strftime("%b %d, %Y") : "—" %>
                </td>
                <td>
                  <% if ingestion.tenant %>
                    <span class="text-sm font-semibold"><%= ingestion.tenant.name %></span>
                  <% else %>
                    <span class="text-xs text-base-content/40 italic">Not matched</span>
                  <% end %>
                </td>
                <td>
                  <% case ingestion.status %>
                  <% when "matched" %>
                    <span class="badge badge-success text-xs font-semibold">Matched</span>
                  <% when "ambiguous" %>
                    <span class="badge badge-warning text-xs font-semibold">Ambiguous</span>
                  <% when "unmatched" %>
                    <span class="badge badge-neutral text-xs font-semibold">Unmatched</span>
                  <% when "failed" %>
                    <span class="badge badge-error text-xs font-semibold">Failed Parse</span>
                  <% else %>
                    <span class="badge text-xs capitalize"><%= ingestion.status %></span>
                  <% end %>
                </td>
                <td class="text-right whitespace-nowrap space-x-1">
                  <%= link_to "Review", payment_ingestion_path(ingestion), class: "btn btn-sm btn-primary" %>
                  <%= link_to "Delete", payment_ingestion_path(ingestion), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this ingestion record? The uploaded PDF binary will be deleted." }, class: "btn btn-sm btn-ghost text-error" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

  <!-- Section: Confirmed / History -->
  <div>
    <h2 class="text-xl font-bold text-base-content mb-4 flex items-center gap-2">
      <span>History</span>
      <span class="badge badge-outline text-xs font-semibold text-base-content/75"><%= @total_confirmed_count %></span>
    </h2>

    <% if @confirmed_ingestions.empty? %>
      <div class="text-center py-6 text-sm text-base-content/50 italic">
        No completed ingestions found.
      </div>
    <% else %>
      <div class="overflow-x-auto card bg-base-100 border border-base-200 shadow-sm">
        <table class="table table-sm w-full">
          <thead>
            <tr>
              <th>Confirmed At</th>
              <th>Payer</th>
              <th>Amount</th>
              <th>Date</th>
              <th>Tenant</th>
              <th>Payment Method</th>
              <th>Transaction Number</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @confirmed_ingestions.each do |ingestion| %>
              <tr>
                <td class="whitespace-nowrap text-xs text-base-content/60">
                  <%= ingestion.updated_at.in_time_zone(Current.session.user.timezone).strftime("%b %d, %Y %I:%M %p") %>
                </td>
                <td class="font-medium text-xs">
                  <%= ingestion.payer_name %>
                </td>
                <td class="font-semibold text-xs">
                  <%= number_to_currency(ingestion.amount) %>
                </td>
                <td class="text-xs">
                  <%= ingestion.payment_date.strftime("%b %d, %Y") %>
                </td>
                <td class="font-medium text-xs">
                  <%= ingestion.tenant&.name %>
                </td>
                <td class="text-xs capitalize">
                  <%= ingestion.payment_method %>
                </td>
                <td class="text-xs font-mono">
                  <%= ingestion.transaction_number.presence || "—" %>
                </td>
                <td class="text-right space-x-1">
                  <%= link_to "Download PDF", download_payment_ingestion_path(ingestion), class: "btn btn-xs btn-outline" %>
                  <%= link_to "Delete Ingestion", payment_ingestion_path(ingestion), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this historical ingestion record? Note: This deletes the ingestion audit trail and PDF, but does NOT delete the confirmed Tenant Payment record." }, class: "btn btn-xs btn-ghost text-error" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @total_pages > 1 %>
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mt-4 px-1">
          <div class="text-xs text-base-content/60">
            Showing <%= (@page - 1) * @per_page + 1 %> to <%= [@page * @per_page, @total_confirmed_count].min %> of <%= @total_confirmed_count %> entries
          </div>
          <div class="join">
            <% if @page > 1 %>
              <%= link_to "«", payment_ingestions_path(page: @page - 1), class: "join-item btn btn-xs btn-outline" %>
            <% else %>
              <button class="join-item btn btn-xs btn-outline btn-disabled" disabled>«</button>
            <% end %>
            
            <button class="join-item btn btn-xs btn-outline no-animation cursor-default">Page <%= @page %> of <%= @total_pages %></button>
            
            <% if @page < @total_pages %>
              <%= link_to "»", payment_ingestions_path(page: @page + 1), class: "join-item btn btn-xs btn-outline" %>
            <% else %>
              <button class="join-item btn btn-xs btn-outline btn-disabled" disabled>»</button>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
