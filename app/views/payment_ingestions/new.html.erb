<% content_for :title, "Upload Payment Document - Yanushi" %>

<% content_for :breadcrumbs do %>
  <li><%= link_to "Payment Ingestions", payment_ingestions_path %></li>
  <li>Upload Document</li>
<% end %>

<div class="max-w-2xl mx-auto mt-8">
  <div class="card bg-base-100 shadow-xl border border-base-200">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold text-primary mb-2">Ingest Payment Document</h2>
      <p class="text-sm text-base-content/70 mb-6">
        Upload a Chase Zelle receipt, Venmo receipt, or monthly Chase checking statement PDF. The system will automatically parse the transactions, extract metadata, and match them to your tenants.
      </p>

      <%= form_with(model: @ingestion, local: true, class: "space-y-6") do |f| %>
        <div class="form-control w-full">
          <label class="label">
            <span class="label-text font-semibold">Select Document PDF</span>
            <span class="label-text-alt text-base-content/50">PDF format</span>
          </label>
          <%= f.file_field :pdf_file, accept: "application/pdf", class: "file-input file-input-bordered file-input-primary w-full" %>
        </div>

        <div class="space-y-4">
          <h3 class="text-xs font-bold text-base-content/60 uppercase tracking-wider">Supported Documents & Formats</h3>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Chase Zelle / P2P -->
            <div class="card bg-base-200/50 border border-base-300 rounded-xl p-4 hover:border-primary/30 transition-all duration-300">
              <div class="flex items-center gap-2 mb-2">
                <span class="badge badge-primary badge-sm font-semibold">Chase</span>
                <span class="text-sm font-bold text-base-content">Zelle & Statements</span>
              </div>
              <ul class="text-xs text-base-content/70 space-y-1 list-disc list-inside">
                <li>Single-payment PDF Zelle receipts</li>
                <li>Multi-page checking account statements</li>
                <li>Extracts Zelle & P2P ACH deposits</li>
              </ul>
            </div>

            <!-- Venmo Receipts -->
            <div class="card bg-base-200/50 border border-base-300 rounded-xl p-4 hover:border-secondary/30 transition-all duration-300">
              <div class="flex items-center gap-2 mb-2">
                <span class="badge badge-secondary badge-sm font-semibold">Venmo</span>
                <span class="text-sm font-bold text-base-content">Venmo Receipts</span>
              </div>
              <ul class="text-xs text-base-content/70 space-y-1 list-disc list-inside">
                <li>"Transaction details" pages saved as PDF</li>
                <li>Single-payment receipts</li>
                <li>Resolves by name or @username handle</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="card-actions justify-end mt-6 gap-3">
          <%= link_to "Cancel", payment_ingestions_path, class: "btn btn-ghost" %>
          <%= f.submit "Upload & Parse", class: "btn btn-primary px-6" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

