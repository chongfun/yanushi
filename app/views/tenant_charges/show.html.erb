<div class="max-w-3xl mx-auto py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold">Tenant Charge</h1>
      <p class="text-base-content/60">Reference: <%= dom_id(@tenant_charge) %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Back to Expenses", expenses_path, class: "btn btn-ghost" %>
    </div>
  </div>

  <div class="card bg-base-100 shadow-xl border border-base-200">
    <div class="card-body">
      <div class="flex flex-col md:flex-row justify-between gap-8">
        <!-- Charge Summary -->
        <div class="space-y-6 flex-1">
          <div>
            <div class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-1">Amount Charged</div>
            <div class="text-4xl font-bold text-error"><%= number_to_currency(@tenant_charge.amount) %></div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <div class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-1">Charge Date</div>
              <div class="text-lg font-medium"><%= @tenant_charge.charge_date.strftime("%B %d, %Y") %></div>
            </div>
            <div>
              <div class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-1">Category</div>
              <div><span class="badge badge-error badge-lg badge-outline font-medium"><%= @tenant_charge.expense.category.humanize %></span></div>
            </div>
          </div>

          <% if @tenant_charge.description.present? %>
            <div>
              <div class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-1">Description</div>
              <div class="text-base bg-base-200 px-4 py-2.5 rounded-lg border border-base-300">
                <%= @tenant_charge.description %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="divider md:divider-horizontal"></div>

        <!-- Property & Lease Details -->
        <div class="space-y-6 flex-1">
          <div>
            <div class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-1">Property Address</div>
            <div class="text-lg font-bold leading-tight"><%= @tenant_charge.lease.rental_property.address %></div>
          </div>

          <div>
            <div class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-1">Tenant Name</div>
            <div class="text-lg font-semibold"><%= @tenant_charge.lease.tenants.pluck(:name).join(', ') %></div>
          </div>
        </div>
      </div>

      <div class="card-actions justify-end mt-10 border-t border-base-200 pt-8">
        <div>
          <%= button_to "Delete Charge", @tenant_charge, method: :delete, 
              class: "btn btn-error btn-ghost", 
              form: { data: { turbo_confirm: "Are you sure you want to delete this tenant charge? This will remove the debit from the tenant's running account." } } %>
        </div>
      </div>
    </div>
  </div>
</div>
