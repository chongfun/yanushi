<% content_for :title, "Editing rental property" %>
<% content_for :breadcrumbs do %>
  <li><%= link_to "Properties", rental_properties_path %></li>
  <li><%= link_to @rental_property.address, @rental_property %></li>
  <li>Edit</li>
<% end %>

<h1 class="text-3xl font-bold mb-6">Editing rental property</h1>

<%= render "form", rental_property: @rental_property %>

<div class="flex gap-4 mt-6">
  <%= link_to "Show this rental property", @rental_property, class: "btn btn-outline" %>
  <%= link_to "Back to rental properties", rental_properties_path, class: "btn btn-ghost" %>
</div>
