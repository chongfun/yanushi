<%= form_with(model: rental_property) do |form| %>
  <% if rental_property.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(rental_property.errors.count, "error") %> prohibited this rental_property from being saved:</h2>

      <ul>
        <% rental_property.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>


  <div>
    <%= form.label :address, style: "display: block" %>
    <%= form.text_field :address %>
  </div>

  <div>
    <%= form.label :property_type, style: "display: block" %>
    <%= form.select :property_type, RentalProperty.property_types.keys.map { |k| [k.humanize, k] } %>
  </div>

  <div>
    <%= form.label :square_footage, style: "display: block" %>
