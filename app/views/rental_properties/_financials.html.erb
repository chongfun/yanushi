<%= turbo_frame_tag "property_financials" do %>
  <div class="flex justify-between items-center mb-4">
    <div class="flex items-center gap-2">
      <%= link_to "＋ Record Expense",
            new_rental_property_expense_path(rental_property),
            class: "btn btn-sm btn-outline btn-error",
            data: { turbo_frame: "modal-frame" } %>
      <% active_lease = active_lease_for(rental_property) %>
      <% if active_lease %>
        <%= link_to "＋ Record Payment",
              new_lease_tenant_payment_path(active_lease),
              class: "btn btn-sm btn-outline btn-primary",
              data: { turbo_frame: "modal-frame" } %>
      <% end %>
      <%= link_to "📋 Schedule E",
            schedule_e_rental_property_path(rental_property, year: year),
            class: "btn btn-sm btn-outline btn-accent",
            data: { turbo_frame: "modal-frame" } %>
    </div>
    <%= form_with url: rental_property_path(rental_property), method: :get, data: { turbo_frame: "property_financials" }, class: "flex items-center gap-2" do |f| %>
      <%= f.label :year, "Select Year", class: "text-sm font-semibold" %>
      <%= f.select :year,
            options_for_select(rental_property.active_years([year]), year),
            {},
            onchange: "this.form.requestSubmit()",
            class: "select select-bordered select-sm" %>
    <% end %>
  </div>

  <div class="overflow-x-auto bg-base-100 rounded-box shadow border border-base-200">
    <table class="table table-zebra w-full">
      <thead>
        <tr>
          <th>Date</th>
          <th>Type</th>
          <th>Details</th>
          <th class="text-right">Amount</th>
        </tr>
      </thead>
      <tbody>
        <% if financial_items.empty? %>
          <tr>
            <td colspan="4" class="text-center py-8 text-base-content/50">
              No financial activity found for <%= year %>
            </td>
          </tr>
        <% else %>
          <% financial_items.each do |item| %>
            <tr>
              <td><%= item[:date].strftime("%b %d, %Y") %></td>
              <td>
                <% case item[:type] %>
                <% when 'Scheduled Rent' %>
                  <div class="badge badge-info gap-2 text-xs"><%= item[:type] %></div>
                <% when 'Tenant Payment' %>
                  <div class="badge badge-success gap-2 text-xs text-success-content"><%= item[:type] %></div>
                <% when 'Expense' %>
                  <div class="badge badge-error gap-2 text-xs text-error-content"><%= item[:type] %></div>
                <% when 'Tenant Charge' %>
                  <div class="badge badge-warning gap-2 text-xs text-warning-content"><%= item[:type] %></div>
                <% end %>
              </td>
              <td class="text-sm">
                <% if item[:type] == 'Scheduled Rent' %>
                  <% if item[:object].covered? %>
                    <span class="badge badge-success badge-sm badge-outline font-medium">Paid</span>
                  <% else %>
                    <span class="badge badge-error badge-sm badge-outline font-medium">Unpaid</span>
                    <% if item[:date] < Date.current %>
                      <span class="text-error ml-2 text-xs font-semibold">Overdue</span>
                    <% end %>
                  <% end %>
                <% elsif item[:type] == 'Tenant Payment' %>
                  Lease #<%= item[:object].lease_id %> (Method: <%= item[:object].payment_method %>)
                <% elsif item[:type] == 'Tenant Charge' %>
                  Charge: <%= item[:object].description %>
                <% elsif item[:type] == 'Expense' %>
                  <%= item[:object].category %> - <%= item[:object].description %>
                  <% if item[:object].reimbursed? %>
                    <span class="badge badge-warning text-xs text-warning-content ml-2">Reimbursable</span>
                  <% end %>
                <% end %>
              </td>
              <td class="text-right font-medium">
                <% if item[:type] == 'Expense' %>
                  <span class="text-error">-<%= number_to_currency(item[:amount]) %></span>
                <% elsif item[:type] == 'Tenant Charge' %>
                  <span class="text-error">-<%= number_to_currency(item[:amount]) %></span>
                <% elsif item[:type] == 'Tenant Payment' %>
                  <span class="text-success">+<%= number_to_currency(item[:amount]) %></span>
                <% elsif item[:type] == 'Scheduled Rent' %>
                  <span class="text-base-content/75"><%= number_to_currency(item[:amount]) %></span>
                <% else %>
                  <%= number_to_currency(item[:amount]) %>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
