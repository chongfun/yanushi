<div class="flex justify-center items-center min-h-[70vh]">
  <div class="card w-full max-w-md bg-base-100 shadow-xl border border-base-200">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold justify-center mb-4">Update your password</h2>
      
      <%= form_with url: password_path(params[:token]), method: :put do |form| %>
        <div class="form-control w-full mb-4">
          <%= form.label :password, class: "label font-semibold" %>
          <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Enter new password", maxlength: 72, class: "input input-bordered w-full" %>
        </div>
        
        <div class="form-control w-full mb-6">
          <%= form.label :password_confirmation, class: "label font-semibold" %>
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repeat new password", maxlength: 72, class: "input input-bordered w-full" %>
        </div>
        
        <%= form.submit "Save", class: "btn btn-primary w-full" %>
      <% end %>
    </div>
  </div>
</div>
