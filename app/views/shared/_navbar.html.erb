<div class="navbar bg-base-100 border-b border-base-200 shadow-sm sticky top-0 z-40">
  <div class="navbar-start">
    <%= link_to root_path, class: "btn btn-ghost text-xl font-bold tracking-tight" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 9.75M4.5 9V21h5.25v-5.25h4.5V21H19.5V9" />
      </svg>
      Yanushi
    <% end %>
  </div>

  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1 gap-1">
      <li>
        <%= link_to "Dashboard", root_path,
            class: "btn btn-ghost btn-sm #{'btn-active' if current_page?(root_path)}" %>
      </li>
      <li>
        <%= link_to "Properties", rental_properties_path,
            class: "btn btn-ghost btn-sm #{'btn-active' if request.path.start_with?('/rental_properties')}" %>
      </li>
      <li>
        <%= link_to "Tenants", tenants_path,
            class: "btn btn-ghost btn-sm #{'btn-active' if request.path.start_with?('/tenants')}" %>
      </li>
      <li>
        <%= link_to "Leases", leases_path,
            class: "btn btn-ghost btn-sm #{'btn-active' if request.path.start_with?('/leases')}" %>
      </li>
      <li>
        <%= link_to "Rent Payments", rent_payments_path,
            class: "btn btn-ghost btn-sm #{'btn-active' if request.path.start_with?('/rent_payments')}" %>
      </li>
      <li>
        <%= link_to "Utility Payments", utility_payments_path,
            class: "btn btn-ghost btn-sm #{'btn-active' if request.path.start_with?('/utility_payments')}" %>
      </li>
      <li>
        <%= link_to "Expenses", expenses_path,
            class: "btn btn-ghost btn-sm #{'btn-active' if request.path.start_with?('/expenses')}" %>
      </li>
      <li>
        <%= link_to "Email Settings", email_configuration_path,
            class: "btn btn-ghost btn-sm #{'btn-active' if request.path.start_with?('/email_configuration') || request.path.start_with?('/payment_emails')}" %>
      </li>
    </ul>
  </div>
 
  <div class="navbar-end">
    <% if authenticated? %>
      <% unread_count = Current.user.notifications.unread.count %>
      <%= link_to notifications_path, class: "btn btn-ghost btn-circle relative mr-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" /></svg>
        <% if unread_count > 0 %>
          <span class="badge badge-primary badge-xs absolute top-2 right-2 p-1.5"><%= unread_count %></span>
        <% end %>
      <% end %>
    <% end %>

    <%# Mobile dropdown %>
    <div class="dropdown dropdown-end lg:hidden">
      <div tabindex="0" role="button" class="btn btn-ghost btn-square">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[100] p-2 shadow bg-base-100 rounded-box w-52 border border-base-200">
        <li><%= link_to "Dashboard", root_path %></li>
        <li><%= link_to "Properties", rental_properties_path %></li>
        <li><%= link_to "Tenants", tenants_path %></li>
        <li><%= link_to "Leases", leases_path %></li>
        <li><%= link_to "Rent Payments", rent_payments_path %></li>
        <li><%= link_to "Expenses", expenses_path %></li>
        <li><%= link_to "Utility Payments", utility_payments_path %></li>
        <li><%= link_to "Email Settings", email_configuration_path %></li>
      </ul>
    </div>
  </div>
</div>
