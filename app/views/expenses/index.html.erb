
<% content_for :title, "Expenses" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold">Expenses</h1>
  <%= link_to "New expense", new_expense_path, class: "btn btn-primary" %>
</div>

<div class="overflow-x-auto bg-base-100 rounded-lg shadow border border-base-200">
  <table class="table table-zebra w-full">
    <thead>
      <tr>
        <th>Property</th>
        <th>Category</th>
        <th>Amount</th>
        <th>Date</th>
        <th>Description</th>
        <th class="text-right">Actions</th>
      </tr>
    </thead>
    <tbody id="expenses">
      <% @expenses.each do |expense| %>
        <%= render expense %>
      <% end %>
    </tbody>
  </table>
</div>


