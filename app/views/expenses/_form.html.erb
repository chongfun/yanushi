<%= form_with(model: expense) do |form| %>
  <% if expense.errors.any? %>
    <div class="alert alert-error shadow-lg mb-6 text-error-content"><div>
      <h3 class="font-bold"><%= pluralize(expense.errors.count, "error") %> prohibited this expense from being saved:</h3>

      <ul>
        <% expense.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control w-full mb-4">
    <%= form.label :rental_property_id, class: "label font-semibold" %>
    <%= form.collection_select :rental_property_id, @rental_properties, :id, :address, {}, { class: "select select-bordered w-full" } %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :category, class: "label font-semibold" %>
    <%= form.select :category, Expense.categories.keys.map { |k| [k.humanize, k] }, {}, { class: "select select-bordered w-full" } %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :amount, class: "label font-semibold" %>
    <%= form.text_field :amount, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :expense_date, class: "label font-semibold" %>
    <%= form.date_field :expense_date, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :description, class: "label font-semibold" %>
    <%= form.text_field :description, class: "input input-bordered w-full" %>
  </div>

  <div class="divider">Tenant Reimbursement</div>

  <div class="form-control mb-4">
    <label class="label cursor-pointer justify-start gap-4">
      <%= form.check_box :tenant_reimbursable, class: "checkbox checkbox-primary" %>
      <span class="label-text font-semibold">Tenant Reimbursable (Charges Tenant Running Account)</span>
    </label>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :reimburse_lease_id, "Lease to Charge", class: "label font-semibold" %>
    <%= form.select :reimburse_lease_id, 
          @leases.map { |l| ["#{l.rental_property.address} - Lease ##{l.id} (#{l.tenants.map(&:name).join(', ')})", l.id] },
          { include_blank: "Select a lease (or auto-assign active lease)..." },
          { class: "select select-bordered w-full" } %>
  </div>

  <div class="form-control w-full mb-4">
    <%= form.label :reimburse_amount, "Charge Amount (Defaults to expense amount if left blank)", class: "label font-semibold" %>
    <%= form.number_field :reimburse_amount, step: "0.01", class: "input input-bordered w-full", placeholder: "e.g. 150.00" %>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary w-full mt-4" %>
  </div>
<% end %>
