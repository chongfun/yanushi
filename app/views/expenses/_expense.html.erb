<tr id="<%= dom_id expense %>">
  <td class="font-medium"><%= expense.rental_property.address %></td>
  <td>
    <span class="badge badge-ghost"><%= expense.category&.humanize %></span>
  </td>
  <td class="font-mono"><%= number_to_currency(expense.amount) %></td>
  <td><%= expense.expense_date %></td>
  <td class="max-w-xs truncate text-sm text-base-content/60"><%= expense.description %></td>
  <td class="text-right">
    <%= link_to "View", expense, class: "btn btn-xs btn-ghost" %>
  </td>
</tr>
