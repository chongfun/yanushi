<div id="<%= dom_id expense %>" class="card bg-base-100 shadow-xl">
  <div class="card-body">
  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Rental property</span>
      <span class="font-medium"><%= expense.rental_property_id %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Category</span>
      <span class="font-medium"><%= expense.category&.humanize %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Amount</span>
      <span class="font-medium"><%= expense.amount %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Expense date</span>
      <span class="font-medium"><%= expense.expense_date %></span>
    </div>

  <div class="mb-2">
      <span class="text-sm text-base-content/70 block">Description</span>
      <span class="font-medium"><%= expense.description %></span>
    </div>

    <div class="card-actions justify-end mt-4">
      <%= link_to "View", expense, class: "btn btn-sm btn-outline" %>
    </div>
  </div>
</div>
