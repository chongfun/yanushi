module PaymentIngestions
  class TenantResolver
    class ResolveResult < Dry::Struct
      def self.matched: (tenant: Tenant, tenants: Array[Tenant]) -> Dry::Monads::Result::Success

      def self.ambiguous: (tenants: Array[Tenant]) -> Dry::Monads::Result::Failure

      def self.unmatched: () -> Dry::Monads::Result::Failure

      def self.Success: (untyped value) -> Dry::Monads::Result::Success

      def self.Failure: (untyped value) -> Dry::Monads::Result::Failure

      def tenant: () -> Tenant?

      def tenants: () -> Array[Tenant]

      def status: () -> Symbol
    end

    def resolve: (untyped user, String? display_name, String? username) -> Dry::Monads::Result

    private

    def find_candidates: (untyped user, String? display_name, String? username) -> Array[Tenant]
  end
end
