module ActionCable
  module Connection
    class Base
      def self.identified_by: (*Symbol identifiers) -> void

      # Dynamically generated by identified_by :current_user
      def current_user: () -> User?
      def current_user=: (User?) -> User?

      def reject_unauthorized_connection: () -> untyped

      def cookies: () -> untyped
    end
  end
end
