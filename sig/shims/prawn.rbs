# Prawn gem has no upstream RBS signatures.
# Covers Document methods used by TenantPayments::ReceiptPdfService.
module Prawn
  class Document
    def self.new: () -> Document

    def text: (String text, **untyped options) -> untyped

    def move_down: (Integer amount) -> untyped

    def render: () -> String
  end
end
